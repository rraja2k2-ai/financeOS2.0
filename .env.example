# Copy this file to .env.local and fill in real values. Never commit .env.local.

# Supabase project (Project Settings → API in the Supabase dashboard).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini API key (https://aistudio.google.com/apikey) — server-side only, used by
# the active AI capture provider.
GEMINI_API_KEY=

# Optional overrides — safe to leave unset, the app falls back to the defaults below.
# GEMINI_MODEL=gemini-2.5-flash
# AI_PROVIDER=gemini
